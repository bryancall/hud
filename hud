# ── Cache ─────────────────────────────────────────────────────────────────────

def load_cache() -> dict | None:
    if CACHE_FILE.exists():
        try:
            with open(CACHE_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            pass
    return None


def save_cache(data: dict):
    BASE_DIR.mkdir(parents=True, exist_ok=True)
    with open(CACHE_FILE, "w") as f:
        json.dump(data, f)


FETCH_STEPS = [
    ("GitHub issues", "issues", fetch_github_issues),
    ("GitHub reviews", "reviews", fetch_reviews),
    ("GitHub PRs", "prs", fetch_my_prs),
    ("Jira tickets", "jira", fetch_jira),
    ("Weather", "weather", fetch_weather),
]


def fetch_all(cfg: dict, console: Console | None = None) -> dict:
    """Fetch all data sources. Shows a spinner if console is provided."""
    data: dict = {}
    if console:
        from rich.status import Status
        with Status("", console=console, spinner="dots") as status:
            for label, key, fn in FETCH_STEPS:
                status.update(f"[{T['detail']}]Fetching {label}...[/]")
                data[key] = fn(cfg)
    else:
        for _, key, fn in FETCH_STEPS:
            data[key] = fn(cfg)
    data["fetched_at"] = time.time()
    return data


# ── Layout Builder ────────────────────────────────────────────────────────────

def build_layout(data: dict) -> Layout:
    issues = data.get("issues", [])
    reviews = data.get("reviews", [])
    prs = data.get("prs", [])
    jira_data = data.get("jira", {"tickets": [], "total": 0})
    weather = data.get("weather")

    weather_rows = 4 + len(weather.get("forecast", [])) if weather else 4

    layout = Layout()
    layout.split_column(
        Layout(name="header", size=1),
        Layout(name="body"),
    )
    layout["body"].split_row(
        Layout(name="sidebar", ratio=2),
        Layout(name="main", ratio=3),
    )
    layout["sidebar"].split_column(
        Layout(name="issues", ratio=1),
        Layout(name="jira", ratio=1),
        Layout(name="weather", size=weather_rows),
    )
    MAX_FIXED = 14
    reviews_rows = max(len(reviews), 1) * 2 + 2
    if reviews_rows <= MAX_FIXED:
        layout["main"].split_column(
            Layout(name="reviews", size=reviews_rows),
            Layout(name="prs"),
        )
    else:
        layout["main"].split_column(
            Layout(name="reviews", ratio=1),
            Layout(name="prs", ratio=1),
        )

    layout["header"].update(build_header())
    layout["issues"].update(build_issues_panel(issues))
    layout["jira"].update(build_jira_panel(jira_data))
    layout["weather"].update(build_weather_panel(weather))
    layout["reviews"].update(build_reviews_panel(reviews))
    layout["prs"].update(build_prs_panel(prs))

    return layout


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="HUD - Heads-Up Display for your workday")
    parser.add_argument("--setup", action="store_true", help="Run interactive setup")
    parser.add_argument("--refresh", type=int, default=60, metavar="SECS",
                        help="Auto-refresh interval in seconds (default: 60, 0 = run once)")
    parser.add_argument("--theme", type=str, default=None, metavar="NAME",
                        help="Override theme (yahoo, ocean, mono, or custom)")
    args = parser.parse_args()

    if args.setup:
        run_setup()
        return

    cfg = load_config()

    if not cfg["github_token"]:
        print("No config found. Run: uv run hud --setup")
        sys.exit(1)

    global T
    theme_name = args.theme or cfg.get("theme", "yahoo")
    T = load_theme(theme_name)

    refresh_secs = args.refresh
    console = Console()
    cached = load_cache()

    if refresh_secs <= 0:
        if cached:
            console.print(build_layout(cached))
            data = fetch_all(cfg)
        else:
            data = fetch_all(cfg, console=console)
            console.print(build_layout(data))
        save_cache(data)
        return

    if cached:
        initial = cached
    else:
        initial = fetch_all(cfg, console=console)
        save_cache(initial)

    try:
        with Live(build_layout(initial), console=console, screen=False, refresh_per_second=1) as live:
            if cached:
                data = fetch_all(cfg)
                save_cache(data)
                live.update(build_layout(data))
            while True:
                time.sleep(refresh_secs)
                data = fetch_all(cfg)
                save_cache(data)
                live.update(build_layout(data))
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
