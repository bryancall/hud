        icon, icon_color = weather_icon(weather["condition"])
        t.add_row(_weather_line(
            " ", icon, icon_color, f"  {weather['temp_f']}°F  {weather['condition']}", T["weather_current"]))
        t.add_row(Text(f" H: {weather['high_f']}°F  L: {weather['low_f']}°F", style=T["weather_hilo"]))
        for fc in weather.get("forecast", []):
            fc_icon, fc_color = weather_icon(fc["condition"])
            t.add_row(_weather_line(
                f" {fc['day']}  ", fc_icon, fc_color, f"  {fc['high_f']}°/{fc['low_f']}°F  {fc['condition']}", T["weather_forecast"]))

    return Panel(
        t,
        title=sect_title("◆", "Weather", location),
        title_align="left",
        border_style=T["border"],
        padding=(0, 1),
    )


def build_reviews_panel(reviews: list[dict]) -> Panel:
    t = Table.grid(padding=0)
    t.add_column(no_wrap=True, overflow="ellipsis")

    if not reviews:
        t.add_row(Text("   No reviews requested", style=T["meta"]))
    else:
        for rv in reviews:
            t.add_row(item(T["reviews"], rv["title"], rv["url"]))
            t.add_row(meta_line(
                (f"#{rv['number']} · {rv['age']} · ", T["meta"]),
                (rv["status"], rv["status_color"]),
            ))

    repo_display = reviews[0]["repo"].split("/")[-1] if reviews else "trafficserver"
    return Panel(
        t,
        title=sect_title("◆", "Reviews", f"{repo_display} ({len(reviews)})"),
        title_align="left",
        border_style=T["border"],
        padding=(0, 1),
    )


