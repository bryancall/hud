def load_config() -> dict:
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE) as f:
            return {**DEFAULT_CONFIG, **json.load(f)}
    return dict(DEFAULT_CONFIG)


def save_config(cfg: dict):
    BASE_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)


def run_setup():
    cfg = load_config()
    print("hud setup\n")
    print("  GitHub token: https://github.com/settings/tokens")
    print("  Create a token with 'repo' scope (classic) or 'Issues: read' + 'Pull requests: read' (fine-grained)\n")

    cfg["github_token"] = input(f"  GitHub token [{cfg['github_token'][:8] + '...' if cfg['github_token'] else ''}]: ").strip() or cfg["github_token"]
    cfg["github_user"] = input(f"  GitHub username [{cfg['github_user']}]: ").strip() or cfg["github_user"]

    repos_input = input(f"  GitHub repos (comma-separated) [{','.join(cfg['github_repos'])}]: ").strip()
    if repos_input:
        cfg["github_repos"] = [r.strip() for r in repos_input.split(",")]

    cfg["jira_email"] = input(f"  Jira email [{cfg['jira_email']}]: ").strip() or cfg["jira_email"]
    cfg["jira_pat_path"] = input(f"  Jira PAT path [{cfg['jira_pat_path']}]: ").strip() or cfg["jira_pat_path"]
    cfg["jira_base_url"] = input(f"  Jira base URL [{cfg['jira_base_url']}]: ").strip() or cfg["jira_base_url"]
    cfg["jira_project"] = input(f"  Jira project [{cfg['jira_project']}]: ").strip() or cfg["jira_project"]
    cfg["weather_zip"] = input(f"  Weather zip code [{cfg['weather_zip']}]: ").strip() or cfg["weather_zip"]

    available = list(BUILTIN_THEMES.keys())
    for tf in THEMES_DIR.glob("*.json"):
        available.append(tf.stem)
    theme_list = ", ".join(sorted(set(available)))
    cfg["theme"] = input(f"  Theme ({theme_list}) [{cfg['theme']}]: ").strip() or cfg["theme"]

    save_config(cfg)
    print(f"\n  Config saved to {CONFIG_FILE}")
    print(f"  Themes dir: {THEMES_DIR}")


