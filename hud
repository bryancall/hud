def fetch_github_issues(cfg: dict) -> list[dict]:
    token = cfg["github_token"]
    user = cfg["github_user"]
    if not token or not user:
        return []

    headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github+json"}
    all_issues = []

    for repo in cfg["github_repos"]:
        url = f"https://api.github.com/search/issues?q=assignee:{user}+is:issue+is:open+repo:{repo}&per_page=100"
        data = api_get(url, headers=headers)
        if not data or "items" not in data:
            continue
        for it in data["items"]:
            labels = [l["name"] for l in it.get("labels", [])]
            first_label = labels[0] if labels else None
            all_issues.append({
                "title": it["title"],
                "number": it["number"],
                "url": it["html_url"],
                "age": fmt_age(it.get("created_at", "")),
                "comments": it.get("comments", 0),
                "label": first_label,
                "repo": repo.split("/")[-1],
            })
    return all_issues


def fetch_reviews(cfg: dict) -> list[dict]:
    token = cfg["github_token"]
    user = cfg["github_user"]
    if not token or not user:
        return []

    headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github+json"}
    all_reviews = []

    for repo in cfg["github_repos"]:
        url = f"https://api.github.com/search/issues?q=review-requested:{user}+is:pr+is:open+repo:{repo}&per_page=100"
        data = api_get(url, headers=headers)
        if not data or "items" not in data:
            continue
        for it in data["items"]:
            status = "⏳ pending"
            status_color = "#dcbe3c"
            if it.get("draft"):
                status = "~ draft"
                status_color = "#968cc8"
            all_reviews.append({
                "title": it["title"],
                "number": it["number"],
                "url": it["html_url"],
                "age": fmt_age(it.get("created_at", "")),
                "status": status,
                "status_color": status_color,
                "repo": repo,
            })
    return all_reviews


def fetch_my_prs(cfg: dict) -> list[dict]:
    token = cfg["github_token"]
    user = cfg["github_user"]
    if not token or not user:
        return []

    headers = {"Authorization": f"token {token}", "Accept": "application/vnd.github+json"}
    all_prs = []

    for repo in cfg["github_repos"]:
        url = f"https://api.github.com/search/issues?q=author:{user}+is:pr+is:open+repo:{repo}&per_page=100"
        data = api_get(url, headers=headers)
        if not data or "items" not in data:
            continue

        for it in data["items"]:
            pr_detail = api_get(it["pull_request"]["url"], headers=headers)

            status = "⏳ awaiting review"
            status_color = "#dcbe3c"
            if it.get("draft") or (pr_detail and pr_detail.get("draft")):
                status = "~ draft"
                status_color = "#968cc8"
            elif pr_detail and pr_detail.get("mergeable_state") == "dirty":
                status = "⚡ merge conflict"
                status_color = "#ff6432"
            elif pr_detail and pr_detail.get("mergeable_state") == "unstable":
                status = "⚠ CI failing"
                status_color = "#ff6432"

            all_prs.append({
                "title": it["title"],
                "number": it["number"],
                "url": it["html_url"],
                "age": fmt_age(it.get("created_at", "")),
                "status": status,
                "status_color": status_color,
                "repo": repo,
            })
    return all_prs


def fetch_jira(cfg: dict) -> dict:
    """Returns {"tickets": [...], "total": N} where total is all unresolved assigned."""
    email = cfg["jira_email"]
    pat_path = os.path.expanduser(cfg["jira_pat_path"])
    base_url = cfg["jira_base_url"]
    if not email or not os.path.exists(pat_path):
        return {"tickets": [], "total": 0}

    try:
        pat = open(pat_path).read().strip()
    except OSError:
        return {"tickets": [], "total": 0}

    jql = "assignee = currentUser() AND resolution = Unresolved ORDER BY updated DESC"
    fields = "key,summary,status,priority,updated"
    url = f"{base_url}/rest/api/3/search/jql?jql={requests.utils.quote(jql)}&maxResults=100&fields={fields}"

    data = api_get(url, auth=(email, pat))
    if not data or "issues" not in data:
        return {"tickets": [], "total": 0}

    total = data.get("total", len(data["issues"]))
    tickets = []
    for issue in data["issues"]:
        f = issue["fields"]
        tickets.append({
            "key": issue["key"],
            "summary": f.get("summary", ""),
            "status": (f.get("status") or {}).get("name", ""),
            "priority": (f.get("priority") or {}).get("name", ""),
            "age": fmt_age(f.get("updated", "")),
            "url": f"{base_url}/browse/{issue['key']}",
        })
    return {"tickets": tickets, "total": total}


