def _abbrev_state(region: str) -> str:
    return US_STATE_ABBREV.get(region, region)


def fetch_weather(cfg: dict) -> dict | None:
    zip_code = cfg.get("weather_zip", "95123")
    data = api_get(f"https://wttr.in/{zip_code}?format=j1")
    if not data:
        return None

    try:
        current = data["current_condition"][0]
        nearest = data.get("nearest_area", [{}])[0]
        city = nearest.get("areaName", [{}])[0].get("value", zip_code)
        region = nearest.get("region", [{}])[0].get("value", "")
        location = f"{city}, {_abbrev_state(region)}" if region else city

        result = {
            "location": location,
            "temp_f": current.get("temp_F", "?"),
            "condition": current.get("weatherDesc", [{}])[0].get("value", "Unknown"),
            "high_f": "?",
            "low_f": "?",
            "forecast": [],
        }

        today = data.get("weather", [{}])[0]
        result["high_f"] = today.get("maxtempF", "?")
        result["low_f"] = today.get("mintempF", "?")

        days = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]
        for w in data.get("weather", [])[1:4]:
            date_str = w.get("date", "")
            try:
                dt = datetime.strptime(date_str, "%Y-%m-%d")
                day_name = days[dt.weekday() + 1] if dt.weekday() < 6 else days[0]
            except ValueError:
                day_name = date_str
            cond = w.get("hourly", [{}])[4].get("weatherDesc", [{}])[0].get("value", "?") if len(w.get("hourly", [])) > 4 else "?"
            result["forecast"].append({
                "day": day_name,
                "high_f": w.get("maxtempF", "?"),
                "low_f": w.get("mintempF", "?"),
                "condition": cond,
            })

        return result
    except (KeyError, IndexError):
        return None


# ── Rendering ─────────────────────────────────────────────────────────────────

def item(color: str, title: str, url: str) -> Text:
    t = Text(" ○ ", style=color)
    lt = Text(title, style=color)
    lt.stylize(f"link {url}")
    t.append_text(lt)
    return t


def meta_line(*parts: tuple[str, str]) -> Text:
    t = Text("   ")
    for text, style in parts:
        t.append(text, style=style)
    return t


def sect_title(icon: str, name: str, detail: str) -> str:
    return f"[{T['section_title']}]{icon} {name}[/] [{T['detail']}]· {detail}[/]"


def build_header() -> Text:
    now = datetime.now()
    day_name = now.strftime("%A")
    date_str = now.strftime("%b %-d")
    time_str = now.strftime("%-H:%M")

    title = Text(justify="left")
    title.append(" ◈", style=f"bold {T['gold']} on {T['border']}")
    title.append("  HUD", style=f"bold {T['gold']} on {T['border']}")
    title.append(f"  ─  {day_name} {date_str}  {time_str}", style=f"{T['gold']} on {T['border']}")
    title.pad_right(300)
    title.stylize(f"on {T['border']}")
    return title


def build_issues_panel(issues: list[dict]) -> Panel:
    t = Table.grid(padding=0)
    t.add_column(no_wrap=True, overflow="ellipsis")

    if not issues:
        t.add_row(Text("   No assigned issues", style=T["meta"]))
    else:
        for iss in issues:
            t.add_row(item(T["issues"], iss["title"], iss["url"]))
            parts = [(f"#{iss['number']} · {iss['age']}", T["meta"])]
            if iss.get("label"):
                lbl = iss["label"]
                lbl_color = LABEL_COLORS.get(lbl, "#b4aae6")
                parts.append((" · ", T["meta"]))
                parts.append((lbl, lbl_color))
            if iss.get("comments", 0) > 0:
                parts.append((f" · {iss['comments']} cmts", T["meta"]))
            t.add_row(meta_line(*parts))

    repo_name = issues[0]["repo"] if issues else "trafficserver"
    return Panel(
        t,
        title=sect_title("◆", "Issues", f"{repo_name} ({len(issues)})"),
        title_align="left",
        border_style=T["border"],
        padding=(0, 1),
    )


def build_jira_panel(jira_data: dict) -> Panel:
    tickets = jira_data.get("tickets", [])
    total = jira_data.get("total", len(tickets))

    t = Table.grid(padding=0)
    t.add_column(no_wrap=True, overflow="ellipsis")

    if not tickets:
        t.add_row(Text("   No Jira tickets", style=T["meta"]))
    else:
        for tk in tickets:
            t.add_row(item(T["jira"], tk["summary"], tk["url"]))
            st_color = JIRA_STATUS_COLORS.get(tk["status"], T["meta"])
            pr_color = JIRA_PRIORITY_COLORS.get(tk["priority"], T["meta"])
            parts: list[tuple[str, str]] = [
                (f"{tk['key']} · ", T["meta"]),
                (tk["status"], st_color),
            ]
            if tk["priority"]:
                parts.append((" · ", T["meta"]))
                parts.append((tk["priority"], pr_color))
            parts.append((f" · {tk['age']}", T["meta"]))
            t.add_row(meta_line(*parts))

    detail = f"YTSATS ({total})" if total == len(tickets) else f"YTSATS ({len(tickets)}/{total})"
    return Panel(
        t,
        title=sect_title("◆", "Jira", detail),
        title_align="left",
        border_style=T["border"],
        padding=(0, 1),
    )


def _weather_line(prefix: str, icon: str, icon_color: str, suffix: str, style: str) -> Text:
    """Build a weather line with a colored emoji icon (2 cells wide)."""
    for ch in icon:
        set_cell_size(ch, 2)
    line = Text(prefix, style=style)
    line.append(icon, style=icon_color)
    line.append(suffix, style=style)
    return line


